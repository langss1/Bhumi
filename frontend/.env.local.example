# ══════════════════════════════════════════════════════════════════
# Bang Bang Protocol — Environment Variables
# Copy ke .env.local, isi nilainya.
# JANGAN commit .env.local ke git.
# ══════════════════════════════════════════════════════════════════

# ── SUPABASE (Database + File Storage) ─────────────────────────────
# Satu akun: profil user, akun verificator, metadata aset, file dokumen
#
# SETUP (gratis, ~5 menit):
# 1. Buka https://app.supabase.com → New Project
# 2. Settings → API → copy "Project URL" dan "anon public" key
# 3. Storage → New Bucket → Name: "documents", Public: ON ✔
# 4. SQL Editor → jalankan schema dari src/lib/supabase.ts (lihat komentar di file)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON=your_supabase_anon_key_here

# ── SMART CONTRACT (isi setelah deploy ke testnet) ──────────────────
# Jalankan di foundry/:
#   forge script script/Deploy.s.sol \
#     --rpc-url https://sepolia.base.org \
#     --broadcast --verify
# Lalu copy alamat deployed ke sini:
NEXT_PUBLIC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ── NETWORK RPC ─────────────────────────────────────────────────────
# Base Sepolia (testnet utama — gas lebih murah)
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org

# Ethereum Sepolia (fallback)
NEXT_PUBLIC_ETH_SEPOLIA_RPC=https://rpc.sepolia.org

# Optional: private RPC via Alchemy (lebih stabil)
# NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# ── WALLETCONNECT (untuk MetaMask Mobile, Rainbow, dll) ─────────────
# Daftar gratis di https://cloud.walletconnect.com → New Project
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id

# ── DEPLOYMENT (untuk foundry saja — TIDAK di-expose ke browser) ────
# Set sebelum jalankan forge script:
#   $env:PRIVATE_KEY = "private_key_tanpa_0x"
# JANGAN masukkan private key ke file ini!
