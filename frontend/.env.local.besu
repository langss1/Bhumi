# ==============================================================
# .env.local UNTUK SEMUA LAPTOP (Bhumi Besu IBFT 2.0)
# ==============================================================
# 
# PETUNJUK: Setiap laptop set NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545
# Masing-masing laptop konek ke NODE BESU LOKAL SENDIRI.
# Ini yang membuat data tetap ada meskipun laptop lain mati!
#
# CATATAN: Semua laptop pakai CONTRACT_ADDRESS yang SAMA
# (address dari hasil deploy di Laptop 1)

# ── Blockchain Connection ──────────────────────────────────────
# Konek ke node Besu yang berjalan di laptop INI sendiri (localhost)
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545

# Fallback: Jika node lokal mati, konek ke Laptop 1 via ZeroTier
# (Uncomment baris di bawah jika diperlukan)
# NEXT_PUBLIC_RPC_URL_FALLBACK=http://10.223.153.80:8545

# ── Smart Contract ─────────────────────────────────────────────
# Isi dengan address hasil deploy (sama di ketiga laptop)
NEXT_PUBLIC_CONTRACT_ADDRESS=0xISI_SETELAH_DEPLOY

# ── IPFS / Pinata ──────────────────────────────────────────────
# JWT dari akun Pinata (dokumen tersimpan di IPFS cloud - tidak hilang)
NEXT_PUBLIC_PINATA_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..-KMqJz9lNnb0Xlgg1EB_rn96bIW1QNN2FPmyWAdoC3M
